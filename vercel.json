{
  "version": 2,
  "public": false,
  "builds": [
    {
      "src": "docs/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/docs/$1"
    },
    {
      "src": "/",
      "dest": "/docs/index.html"
    }
  ]
}